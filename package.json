{
  "name": "wlaudio",
  "version": "0.3.0",
  "description": "Real-time web frontend for monitoring Claude Code sessions",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc --noEmit && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "db:query": "tsx scripts/db-query.ts",
    "db:query:list": "tsx scripts/db-query.ts --list",
    "clean": "rm -rf dist coverage test-results",
    "precommit": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "express": "^4.19.0",
    "ws": "^8.17.0"
  }
}
